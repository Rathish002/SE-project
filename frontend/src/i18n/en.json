  "lessonData": {
    "lesson-1": {
      "title": "Greetings and Basic Phrases",
      "description": "Learn to greet people and use basic phrases in everyday conversation.",
      "microSteps": [
        "Read",
        "Practice",
        "Learn"
      ],
      "steps": [
        {
          "content": "What is said when you meet someone?",
          "task": "Answer the question",
          "instruction": "Select the correct option",
          "hints": [
            "It is the most common greeting",
            "Think carefully",
            "Choose the best option"
          ],
          "options": [
            "Namaste",
            "Sorry",
            "Goodbye",
            "Thank you"
          ],
          "correct": "Namaste"
        },
        {
          "content": "What is the proper greeting for the morning?",
          "task": "Answer the question",
          "instruction": "Select the correct option",
          "hints": [
            "It includes the word for morning",
            "Think carefully",
            "Choose the best option"
          ],
          "options": [
            "Good morning",
            "Afternoon",
            "Good night",
            "Good evening"
          ],
          "correct": "Good morning"
        },
        {
          "content": "What do you say when meeting someone in the evening?",
          "task": "Answer the question",
          "instruction": "Select the correct option",
          "hints": [
            "Time of evening",
            "Think carefully",
            "Choose the best option"
          ],
          "options": [
            "Good evening",
            "Good night",
            "Good morning",
            "Namaste"
          ],
          "correct": "Good evening"
        },
        {
          "content": "Which word can be used besides 'Namaste'?",
          "task": "Answer the question",
          "instruction": "Select the correct option",
          "hints": [
            "It is slightly more formal",
            "Think carefully",
            "Choose the best option"
          ],
          "options": [
            "Namaskar",
            "Goodbye",
            "Thank you",
            "Good morning"
          ],
          "correct": "Namaskar"
        },
        {
          "content": "Why are greetings important in communication?",
          "task": "Answer the question",
          "instruction": "Select the correct option",
          "hints": [
            "It helps to connect people",
            "Think carefully",
            "Choose the best option"
          ],
          "options": [
            "To fight",
            "To connect",
            "To sleep",
            "To run away"
          ],
          "correct": "To connect"
        },
        {
          "content": "Is it important to practice speaking out loud?",
          "task": "Answer the question",
          "instruction": "Select the correct option",
          "hints": [
            "Advice at the end of the lesson",
            "Think carefully",
            "Choose the best option"
          ],
          "options": [
            "Maybe",
            "Never",
            "No",
            "Yes"
          ],
          "correct": "Yes"
        }
      ]
    },
    "lesson-2": {
      "title": "Numbers and Counting",
      "description": "Numbers are everywhere in our daily lives. We use them for counting, measuring, and describing quantities.",
